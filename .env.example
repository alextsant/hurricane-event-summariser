# Mistral AI — https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Brave Search — https://api.search.brave.com/app/dashboard
BRAVE_API_KEY=your_brave_api_key_here

# ElevenLabs TTS — https://elevenlabs.io/app/settings/api-keys
# Text to Speech enabled only (Voices in read mode as well) 
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # "Adam" (free default voice)

# Polling interval in minutes for background storm detection (default 60)
POLL_INTERVAL_MINUTES=60

# Your real email — required by Nominatim ToS for geocoding to work (no account needed)
NOMINATIM_EMAIL=your_email@example.com
